{
   "action": {
      "default_icons": {
         "32": "images/colored-32.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "event.js"
   },
   "commands": {
      "_execute_action": {
         "suggested_key": {
            "default": "Alt+S",
            "linux": "Alt+S",
            "mac": "MacCtrl+Command+S",
            "windows": "Alt+S"
         }
      },
      "toggle-page-metrics": {
         "description": "Toggle Metrics bar",
         "suggested_key": {
            "default": "Alt+A",
            "linux": "Alt+A",
            "mac": "MacCtrl+Command+A",
            "windows": "Alt+A"
         }
      }
   },
   "content_scripts": [ {
      "css": [ "content.css" ],
      "exclude_globs": [ "https://*.ahrefs.com/*", "https://*.ahrefs.me/*" ],
      "exclude_matches": [ "https://www.bing.com/*", "https://www.facebook.com.login.php/", "*://*/*.pdf", "*://*/*.txt", "*://*/*.xml" ],
      "js": [ "content.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_idle"
   }, {
      "exclude_globs": [ "https://*.ahrefs.com/*" ],
      "exclude_matches": [ "https://www.bing.com/*", "https://www.facebook.com.login.php/", "*://*/*.pdf", "*://*/*.txt", "*://*/*.xml" ],
      "js": [ "content-service.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_idle"
   } ],
   "default_locale": "en",
   "description": "__MSG_manifest_description__",
   "homepage_url": "https://ahrefs.com/",
   "host_permissions": [ "*://*/*", "https://ahrefs.com/v4/", "https://app.ahrefs.com/" ],
   "icons": {
      "128": "images/colored-128.png",
      "48": "images/colored-48.png",
      "64": "images/colored-64.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Ahrefs SEO Toolbar",
   "permissions": [ "declarativeNetRequestWithHostAccess", "identity", "tabs", "storage", "webNavigation", "webRequest" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "3.2.9",
   "web_accessible_resources": [ {
      "matches": [ "*://*/*" ],
      "resources": [ "images/countries/*.svg", "images/check.svg" ]
   } ]
}
